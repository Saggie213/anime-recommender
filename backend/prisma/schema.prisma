datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique
  email          String          @unique
  passwordHash   String
  favoriteGenres String          @default("") // Comma-separated list of genres, e.g. "Action,Sci-Fi"
  createdAt      DateTime        @default(now())
  watchList      UserAnimeList[]
}

model Anime {
  id          Int             @id // Matches MAL / AniList ID
  title       String
  synopsis    String
  genres      String          // Comma-separated list of genres
  studio      String
  releaseYear Int
  episodes    Int
  rating      String          // E.g. "PG-13", "R - 17+"
  score       Float           // E.g. 8.92
  popularity  Int             // Popularity index or member count
  imageUrl    String
  status      String          // E.g. "Finished Airing", "Currently Airing"
  userLists   UserAnimeList[]
}

model UserAnimeList {
  userId          Int
  animeId         Int
  status          String        // "WATCHING", "COMPLETED", "PLAN_TO_WATCH", "DROPPED"
  rating          Int?          // User rating 1-10
  watchedEpisodes Int           @default(0)
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime           Anime         @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@id([userId, animeId])
}
